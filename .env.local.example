# 素问居 - 环境变量配置示例
# 复制为 .env.local 并填入真实 Key

# ========== AI 服务 ==========
# DeepSeek API Key（用于 AI 养生顾问功能）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ========== 支付（可选）==========
# 微信收款码（用于付费解锁功能）
# NEXT_PUBLIC_WECHAT_QR_URL=/images/wechat-qr.jpg

# ========== Cloudflare Pages 部署 ==========
# 如果使用 Cloudflare Pages 构建，需要在 Pages 设置中添加此变量
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
